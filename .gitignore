# ───────────────────────── dependencies ─────────────────────────
node_modules/
.pnp
.pnp.js

# ──────────────────── environment secrets ───────────────────────
# Ignore real env files everywhere; keep the *.env.example templates.
.env
.env.*
!.env.example
!**/.env.example

# ─────────────────────── build output ───────────────────────────
dist/
build/
.vite/
*.tsbuildinfo

# ──────────────────────── logs / debug ──────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ──────────────── coverage / test artifacts ─────────────────────
coverage/
.nyc_output/

# ─────────────────────── OS / editor junk ───────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ─────────────────────── local tooling ──────────────────────────
.claude/

# ─────────────── internal working docs (kept local) ─────────────
# Team-only markdown (demo/video script, validation & submission
# checklists, manual test plan, internal setup/API notes) stay local.
# The public README + diagrams/ + the shipped diagram images in docs/
# are the published documentation.
docs/*
# …but publish the rendered diagrams referenced by the README:
!docs/system-architecture.png
!docs/system-architecture.html
!docs/hardware-schematic.png
