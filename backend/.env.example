# ---- Required ----
# Port the backend listens on
PORT=5000
# Origin allowed to call the REST API / connect via Socket.IO (the dashboard dev server)
CLIENT_URL=http://localhost:5173

# ---- Optional demo / tuning knobs (defaults shown, uncomment to override) ----
# How often the simulator toggles one random device (milliseconds)
# SIMULATION_INTERVAL_MS=5000
# Office hours used by the alert engine (24h clock, local server time)
# OFFICE_START_HOUR=9
# OFFICE_END_HOUR=17
# How long a whole room must be ON before the long-running alert fires (hours)
# LONG_RUNNING_HOURS=2
#
# Demo tip: set OFFICE_START_HOUR=24 to force "after-hours" mode at any time of day,
# and LONG_RUNNING_HOURS=0.01 to see the long-running room alert quickly.
