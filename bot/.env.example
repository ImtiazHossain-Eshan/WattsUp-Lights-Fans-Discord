# Discord bot token — Discord Developer Portal → your app → Bot → Reset Token
# IMPORTANT: also enable "MESSAGE CONTENT INTENT" on the same Bot page,
# otherwise the bot cannot read !commands.
DISCORD_TOKEN=your_discord_bot_token_here

# The shared backend (same one the dashboard uses)
BACKEND_URL=http://localhost:5000

# Channel that receives proactive alert posts. Right-click a channel →
# "Copy Channel ID" (enable Developer Mode in Discord settings first).
# Leave unset to disable proactive alerts — commands still work.
ALERT_CHANNEL_ID=your_discord_channel_id_here
